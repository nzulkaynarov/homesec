# Скопируйте в .env и заполните своими значениями

# Доступ в панель HomeSec
HS_ADMIN_USERNAME=admin
HS_ADMIN_PASSWORD=change-me-strong-password
# Случайная строка для подписи сессий: openssl rand -hex 32
HS_SECRET_KEY=change-me-random-hex

# MikroTik RouterOS API (пользователь создаётся скриптом homesec-base.rsc)
HS_MIKROTIK_HOST=192.168.88.1
HS_MIKROTIK_USER=homesec
HS_MIKROTIK_PASSWORD=change-me

# AdGuard Home на этом же Pi
HS_ADGUARD_URL=http://127.0.0.1:3000
HS_ADGUARD_USERNAME=admin
HS_ADGUARD_PASSWORD=change-me

# Блокировать ли интернет неизвестным устройствам, пока их не одобрили
HS_BLOCK_UNKNOWN=false

# Путь к базе SQLite
HS_DATABASE_PATH=./homesec.db

# Telegram-бот (@BotFather -> токен). Пустой токен = бот выключен.
HS_TELEGRAM_BOT_TOKEN=
# Через запятую: id чатов, которым разрешены команды и куда шлются алерты.
# Свой id можно узнать у @userinfobot.
HS_TELEGRAM_CHAT_IDS=
# URL панели для health-проверки ботом
HS_PANEL_URL=http://127.0.0.1:8000

# ИИ-фичи (дайджест, NL-команды, алерты). Пустой ключ = ИИ выключен,
# всё остальное работает. Ключ: https://platform.claude.com/
HS_ANTHROPIC_API_KEY=
# Модель для рассуждений (NL-команды, дайджест) и дешёвая для рутины
HS_AI_MODEL=claude-opus-4-8
HS_AI_MODEL_FAST=claude-haiku-4-5
# Дневной лимит токенов (вход+выход) на все ИИ-фичи; 0 = без лимита
HS_AI_DAILY_TOKEN_BUDGET=300000
