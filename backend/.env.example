# Скопируйте в .env и заполните своими значениями

# Доступ в панель HomeSec
HS_ADMIN_USERNAME=admin
HS_ADMIN_PASSWORD=change-me-strong-password
# Случайная строка для подписи сессий: openssl rand -hex 32
HS_SECRET_KEY=change-me-random-hex

# MikroTik RouterOS API (пользователь создаётся скриптом homesec-base.rsc)
HS_MIKROTIK_HOST=192.168.88.1
HS_MIKROTIK_USER=homesec
HS_MIKROTIK_PASSWORD=change-me

# AdGuard Home на этом же Pi
HS_ADGUARD_URL=http://127.0.0.1:3000
HS_ADGUARD_USERNAME=admin
HS_ADGUARD_PASSWORD=change-me

# Блокировать ли интернет неизвестным устройствам, пока их не одобрили
HS_BLOCK_UNKNOWN=false

# Путь к базе SQLite
HS_DATABASE_PATH=./homesec.db
